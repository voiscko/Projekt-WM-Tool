<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>WM-Tipp-Tool</AssemblyName>
    <RootNamespace>WMTippTool</RootNamespace>
    <ApplicationManifest>app.manifest</ApplicationManifest>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="MySql.Data" Version="9.1.0" />
  </ItemGroup>

  <!-- db.config: lokale Konfigurationsdatei (nicht in Git) -->
  <!-- db.config.example: Vorlage für neue Nutzer (liegt in Git) -->
  <ItemGroup>
    <None Update="db.config.example">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <!-- db.config nur kopieren wenn vorhanden (existiert nicht in Git) -->
    <None Update="db.config" Condition="Exists('db.config')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
